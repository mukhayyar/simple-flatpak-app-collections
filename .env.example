# Template for .env (copy to .env and fill in real values). .env is gitignored.

# Default single-account login used by auto-run.sh
AGL_EMAIL=developer@agl-store.cyou
AGL_PASSWORD=changeme

# Optional endpoint overrides (defaults shown)
# AGL_ADMIN=https://admin.agl-store.cyou
# AGL_HUB=https://hub.agl-store.cyou/

# Account rotation pool for publish-rotate.sh — space-separated "email:password".
ACCOUNTS="dev1@example.cyou:changeme dev2@example.cyou:changeme"
